<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CerpenKita — Belajar Cerita Pendek</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1208;
    --parchment: #f5ede0;
    --cream: #faf6ef;
    --amber: #c8823a;
    --amber-light: #e8a85a;
    --rust: #8b3a1e;
    --sage: #4a6741;
    --sage-light: #6a8f60;
    --mist: #e8e0d4;
    --shadow: rgba(26,18,8,0.12);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ---- HEADER ---- */
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(250,246,239,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--mist);
    padding: 0 2.5rem;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.5px;
  }
  .logo span { color: var(--amber); }

  nav { display: flex; gap: 0.25rem; }
  nav a {
    text-decoration: none;
    color: var(--ink);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 100px;
    transition: all 0.2s;
  }
  nav a:hover { background: var(--mist); }
  nav a.active { background: var(--ink); color: var(--cream); }

  /* ---- HERO ---- */
  .hero {
    padding-top: 64px;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding-left: 6vw;
    padding-right: 6vw;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(200,130,58,0.08) 0%, transparent 70%),
                radial-gradient(ellipse 40% 50% at 10% 80%, rgba(74,103,65,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--amber); color: #fff;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -1px;
    margin-bottom: 1.25rem;
    color: var(--ink);
  }

  .hero h1 em {
    font-style: italic;
    color: var(--amber);
  }

  .hero p {
    font-size: 1.05rem;
    color: #5a4a38;
    max-width: 44ch;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    font-size: 0.9rem; font-weight: 600;
    text-decoration: none; cursor: pointer; border: none;
    transition: all 0.25s;
  }
  .btn-primary { background: var(--ink); color: var(--cream); }
  .btn-primary:hover { background: var(--rust); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,18,8,0.2); }
  .btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); }
  .btn-outline:hover { background: var(--ink); color: var(--cream); }

  .hero-visual {
    position: relative;
    display: flex; justify-content: center; align-items: center;
  }

  .book-card {
    background: white;
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 4px 6px var(--shadow), 0 20px 60px rgba(26,18,8,0.1);
    width: 100%; max-width: 380px;
    position: relative;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .book-card::before {
    content: '';
    position: absolute; top: -2px; left: 2rem; right: 2rem;
    height: 4px; border-radius: 0 0 4px 4px;
    background: linear-gradient(90deg, var(--amber), var(--rust));
  }

  .bc-tag {
    display: inline-block;
    background: #fff8ee;
    color: var(--amber);
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.3rem 0.65rem; border-radius: 6px;
    border: 1px solid #f0d8a8;
    margin-bottom: 1rem;
  }

  .bc-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem; font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .bc-excerpt {
    font-size: 0.88rem;
    color: #6b5a48;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-style: italic;
    border-left: 3px solid var(--amber);
    padding-left: 0.85rem;
  }

  .bc-meta {
    display: flex; gap: 1rem;
    font-size: 0.78rem; color: #9a8a78;
  }

  .bc-meta span { display: flex; align-items: center; gap: 0.35rem; }

  .floating-tag {
    position: absolute;
    background: var(--sage); color: white;
    font-size: 0.75rem; font-weight: 600;
    padding: 0.4rem 0.85rem; border-radius: 100px;
    white-space: nowrap;
  }
  .ft1 { top: 10%; right: -5%; animation: float 5s ease-in-out infinite 0.5s; }
  .ft2 { bottom: 15%; left: -8%; animation: float 7s ease-in-out infinite 1s; }

  /* ---- STATS ---- */
  .stats {
    background: var(--ink);
    color: var(--cream);
    padding: 3rem 6vw;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem; font-weight: 900;
    color: var(--amber);
    display: block;
  }
  .stat-label { font-size: 0.85rem; opacity: 0.7; margin-top: 0.25rem; }

  /* ---- SECTION ---- */
  .section {
    padding: 6rem 6vw;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-eyebrow {
    font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--ink);
  }

  .section-subtitle {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: #6b5a48;
    max-width: 56ch;
    margin-left: auto; margin-right: auto;
  }

  /* ---- TABS ---- */
  .tab-nav {
    display: flex; gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .tab-btn {
    padding: 0.55rem 1.2rem;
    border-radius: 100px;
    font-size: 0.875rem; font-weight: 600;
    cursor: pointer; border: 1.5px solid var(--mist);
    background: white; color: var(--ink);
    transition: all 0.2s;
  }
  .tab-btn:hover { border-color: var(--amber); color: var(--amber); }
  .tab-btn.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }

  .tab-panel { display: none; animation: fadeIn 0.35s ease; }
  .tab-panel.active { display: block; }

  @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

  /* ---- DEFINITION CARD ---- */
  .def-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .def-card {
    background: white;
    border-radius: 16px;
    padding: 2.25rem;
    box-shadow: 0 2px 16px var(--shadow);
    border-left: 4px solid var(--amber);
  }

  .def-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem; font-weight: 700;
    margin-bottom: 0.85rem;
  }

  .def-card p { font-size: 0.93rem; color: #5a4a38; line-height: 1.75; }

  .highlight-box {
    background: linear-gradient(135deg, #fff8ee, #fff3e0);
    border: 1px solid #f0d8a8;
    border-radius: 16px;
    padding: 2.25rem;
  }

  .highlight-box h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem; font-weight: 700;
    margin-bottom: 1rem;
    color: var(--rust);
  }

  .point-list { list-style: none; }
  .point-list li {
    padding: 0.6rem 0;
    border-bottom: 1px solid #eedbb8;
    font-size: 0.9rem;
    display: flex; gap: 0.75rem; align-items: flex-start;
  }
  .point-list li:last-child { border-bottom: none; }
  .point-list li::before {
    content: '◆';
    color: var(--amber);
    font-size: 0.65rem;
    margin-top: 0.3rem;
    flex-shrink: 0;
  }

  /* ---- UNSUR TABLE ---- */
  .unsur-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .unsur-card {
    background: white;
    border-radius: 14px;
    padding: 1.75rem;
    box-shadow: 0 2px 12px var(--shadow);
    transition: transform 0.25s, box-shadow 0.25s;
    position: relative;
    overflow: hidden;
  }

  .unsur-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--amber), var(--amber-light));
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }
  .unsur-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(26,18,8,0.12); }
  .unsur-card:hover::after { transform: scaleX(1); }

  .unsur-icon {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--amber), var(--amber-light));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .unsur-card h4 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem; font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }

  .unsur-card p { font-size: 0.85rem; color: #6b5a48; line-height: 1.65; }

  /* ---- STRUKTUR ---- */
  .struktur-timeline {
    max-width: 700px; margin: 0 auto;
    position: relative;
  }

  .struktur-timeline::before {
    content: '';
    position: absolute; left: 32px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--amber), transparent);
  }

  .st-item {
    display: flex; gap: 1.5rem;
    margin-bottom: 2rem;
    animation: fadeIn 0.5s ease both;
  }

  .st-num {
    width: 64px; height: 64px; flex-shrink: 0;
    background: var(--ink); color: var(--amber);
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 900;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    position: relative; z-index: 1;
    box-shadow: 0 4px 16px rgba(26,18,8,0.2);
  }

  .st-body {
    background: white; border-radius: 12px;
    padding: 1.4rem 1.75rem;
    flex: 1;
    box-shadow: 0 2px 12px var(--shadow);
  }

  .st-body h4 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem; font-weight: 700;
    margin-bottom: 0.4rem;
    color: var(--rust);
  }

  .st-body p { font-size: 0.88rem; color: #5a4a38; }

  /* ---- CERPEN EXAMPLE ---- */
  .cerpen-wrapper {
    max-width: 760px; margin: 0 auto;
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 40px rgba(26,18,8,0.1);
    overflow: hidden;
  }

  .cerpen-header {
    background: var(--ink);
    padding: 2.5rem;
    color: var(--cream);
    position: relative;
  }

  .cerpen-header::before {
    content: '"';
    font-family: 'Playfair Display', serif;
    font-size: 12rem;
    color: rgba(200,130,58,0.15);
    position: absolute; top: -2rem; left: 1rem;
    line-height: 1;
    pointer-events: none;
  }

  .ch-genre {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--amber-light); font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .ch-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 800; font-style: italic;
    margin-bottom: 0.35rem;
  }

  .ch-author { font-size: 0.88rem; opacity: 0.65; }

  .cerpen-body {
    padding: 2.5rem;
  }

  .cerpen-body p {
    font-size: 0.97rem; line-height: 1.9;
    color: #2c2010;
    margin-bottom: 1.25rem;
    text-indent: 2em;
  }

  .cerpen-body p:first-child { text-indent: 0; }

  .analysis-panel {
    background: #faf6ef;
    border-top: 1px solid var(--mist);
    padding: 2rem 2.5rem;
  }

  .ap-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem; font-weight: 700;
    color: var(--amber);
    margin-bottom: 1.25rem;
    display: flex; align-items: center; gap: 0.5rem;
  }

  .ap-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .ap-item {
    background: white; border-radius: 10px;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--sage);
  }
  .ap-item strong { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--sage); display: block; margin-bottom: 0.3rem; }
  .ap-item span { font-size: 0.875rem; color: #3a2c1e; }

  /* ---- CIRI-CIRI ---- */
  .ciri-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }

  .ciri-card {
    background: white; border-radius: 14px; padding: 1.75rem;
    display: flex; gap: 1.25rem;
    box-shadow: 0 2px 12px var(--shadow);
    transition: transform 0.2s;
  }
  .ciri-card:hover { transform: translateY(-3px); }

  .ciri-icon {
    width: 50px; height: 50px; flex-shrink: 0;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.35rem;
  }
  .icon-amber { background: #fff3e0; }
  .icon-sage { background: #eef3ed; }
  .icon-rust { background: #fdf0ec; }
  .icon-blue { background: #eef3ff; }

  .ciri-card h4 { font-family: 'DM Serif Display', serif; font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
  .ciri-card p { font-size: 0.85rem; color: #6b5a48; line-height: 1.6; }

  /* ---- JENIS CERPEN ---- */
  .jenis-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .jenis-card {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 16px var(--shadow);
    transition: transform 0.25s;
  }
  .jenis-card:hover { transform: translateY(-5px); }

  .jc-header {
    padding: 1.5rem;
    color: white;
    position: relative;
  }
  .jc-h1 { background: linear-gradient(135deg, #8b3a1e, #c8823a); }
  .jc-h2 { background: linear-gradient(135deg, #4a6741, #6a8f60); }
  .jc-h3 { background: linear-gradient(135deg, #2c4a6e, #4a7aae); }
  .jc-h4 { background: linear-gradient(135deg, #6e2c6e, #ae4aae); }
  .jc-h5 { background: linear-gradient(135deg, #1a3a2c, #2a6a4c); }
  .jc-h6 { background: linear-gradient(135deg, #4a3a0e, #8a6a1e); }

  .jc-num {
    font-family: 'Playfair Display', serif;
    font-size: 3rem; font-weight: 900; opacity: 0.2;
    position: absolute; right: 1rem; top: 0.5rem;
  }

  .jc-header h4 { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; position: relative; }
  .jc-header p { font-size: 0.8rem; opacity: 0.85; margin-top: 0.25rem; position: relative; }

  .jc-body { background: white; padding: 1.25rem 1.5rem; }
  .jc-body ul { list-style: none; }
  .jc-body ul li { font-size: 0.83rem; color: #5a4a38; padding: 0.3rem 0; display: flex; gap: 0.5rem; }
  .jc-body ul li::before { content: '→'; color: var(--amber); font-weight: 700; }

  /* ---- TIPS ---- */
  .tips-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }

  .tip-card {
    background: white; border-radius: 16px;
    padding: 2rem; box-shadow: 0 2px 16px var(--shadow);
    position: relative;
  }

  .tip-step {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem; font-weight: 900;
    color: var(--amber); opacity: 0.15;
    position: absolute; right: 1.5rem; top: 1rem;
    line-height: 1;
  }

  .tip-card h4 { font-family: 'DM Serif Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 0.6rem; color: var(--rust); }
  .tip-card p { font-size: 0.88rem; color: #5a4a38; line-height: 1.7; }

  /* ---- QUIZ ---- */
  .quiz-wrap {
    max-width: 680px; margin: 0 auto;
    background: white; border-radius: 20px;
    box-shadow: 0 4px 32px rgba(26,18,8,0.1);
    overflow: hidden;
  }

  .quiz-header {
    background: linear-gradient(135deg, var(--ink), #3a2c1e);
    padding: 2rem 2.5rem; color: var(--cream);
  }
  .quiz-header h3 { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 800; }
  .quiz-header p { font-size: 0.85rem; opacity: 0.65; margin-top: 0.3rem; }

  .quiz-body { padding: 2.5rem; }

  .q-num {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--amber); font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .q-text {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem; font-weight: 700;
    margin-bottom: 1.25rem; line-height: 1.4;
  }

  .q-options { display: flex; flex-direction: column; gap: 0.65rem; }

  .q-opt {
    padding: 0.85rem 1.25rem;
    border: 1.5px solid var(--mist);
    border-radius: 10px;
    font-size: 0.9rem;
    cursor: pointer; background: white;
    text-align: left;
    transition: all 0.2s;
    display: flex; align-items: center; gap: 0.75rem;
  }
  .q-opt:hover { border-color: var(--amber); background: #fff8ee; }
  .q-opt.correct { background: #eef5ec; border-color: var(--sage); color: var(--sage); }
  .q-opt.wrong { background: #fdf0ec; border-color: var(--rust); color: var(--rust); }
  .q-opt.selected { border-color: var(--amber); background: #fff3e0; }

  .q-opt-letter {
    width: 28px; height: 28px; flex-shrink: 0;
    background: var(--mist); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700; color: var(--ink);
    transition: all 0.2s;
  }
  .q-opt.correct .q-opt-letter { background: var(--sage); color: white; }
  .q-opt.wrong .q-opt-letter { background: var(--rust); color: white; }

  .quiz-nav {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 2rem; padding-top: 1.5rem;
    border-top: 1px solid var(--mist);
  }

  .quiz-progress {
    font-size: 0.8rem; color: #9a8a78;
    display: flex; align-items: center; gap: 0.5rem;
  }

  .progress-dots { display: flex; gap: 0.35rem; }
  .pdot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--mist); transition: background 0.3s;
  }
  .pdot.done { background: var(--amber); }
  .pdot.current { background: var(--ink); }

  #quiz-result {
    display: none;
    text-align: center; padding: 2rem;
  }
  .result-score {
    font-family: 'Playfair Display', serif;
    font-size: 4rem; font-weight: 900; color: var(--amber);
  }
  .result-msg { font-size: 1rem; color: #5a4a38; margin-top: 0.5rem; }

  /* ---- FOOTER ---- */
  footer {
    background: var(--ink); color: var(--cream);
    text-align: center;
    padding: 3rem 2rem;
  }
  footer .logo { color: var(--cream); margin-bottom: 0.75rem; display: block; }
  footer p { font-size: 0.83rem; opacity: 0.5; }

  /* ---- SCROLL ANIMATIONS ---- */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding-top: 80px; gap: 2rem; text-align: center; }
    .hero-btns { justify-content: center; }
