<script>
// ---- TAB SWITCHING ----
function switchTab(id, btn) {
  const parent = btn.closest('section') || document;
  const panels = parent.querySelectorAll('.tab-panel');
  const btns = btn.closest('.tab-nav').querySelectorAll('.tab-btn');
  panels.forEach(p => p.classList.remove('active'));
  btns.forEach(b => b.classList.remove('active'));
  const target = document.getElementById(id);
  if (target) target.classList.add('active');
  btn.classList.add('active');
}

// ---- SCROLL REVEAL ----
const ro = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      ro.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => ro.observe(el));

// ---- NAV ACTIVE ----
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('nav a');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => {
    if (window.scrollY >= s.offsetTop - 120) current = s.id;
  });
  navLinks.forEach(a => {
    a.classList.remove('active');
    if (a.getAttribute('href') === '#' + current) a.classList.add('active');
  });
});

// ---- QUIZ ----
const questions = [
  {
    q: "Menurut Edgar Allan Poe, ciri utama cerpen yang membedakannya dari novel adalah…",
    opts: ["Memiliki banyak tokoh dan konflik", "Dapat dibaca dalam sekali duduk dan memberikan satu efek", "Menggunakan bahasa yang sangat puitis", "Selalu memiliki akhir yang bahagia"],
    ans: 1
  },
  {
    q: "Unsur intrinsik cerpen yang menjelaskan 'cara pengarang menyampaikan cerita dari sudut pandang siapa' disebut…",
    opts: ["Amanat", "Gaya bahasa", "Sudut pandang", "Latar"],
    ans: 2
  },
  {
    q: "Bagian struktur cerpen yang merupakan puncak ketegangan konflik disebut…",
    opts: ["Orientasi", "Komplikasi", "Evaluasi (Klimaks)", "Resolusi"],
    ans: 2
  },
  {
    q: "Latar belakang pengarang, kondisi sosial masyarakat, dan nilai moral termasuk dalam unsur…",
    opts: ["Intrinsik cerpen", "Ekstrinsik cerpen", "Struktural cerpen", "Naratif cerpen"],
    ans: 1
  },
  {
    q: "Teknik memulai cerita langsung dari tengah peristiwa (bukan dari awal kronologis) disebut…",
    opts: ["Flashback", "In medias res", "Foreshadowing", "Cliffhanger"],
    ans: 1
  }
];

let qIdx = 0, score = 0, answered = false;

function renderQuestion() {
  const q = questions[qIdx];
  document.getElementById('q-current').textContent = qIdx + 1;
  document.getElementById('q-text').textContent = q.q;
  const opts = document.getElementById('q-options');
  opts.innerHTML = '';
  const letters = ['A','B','C','D'];
  q.opts.forEach((o, i) => {
    const btn = document.createElement('button');
    btn.className = 'q-opt';
    btn.innerHTML = `<span class="q-opt-letter">${letters[i]}</span>${o}`;
    btn.onclick = () => selectOpt(i, btn);
    opts.appendChild(btn);
  });
  renderDots();
  document.getElementById('q-next').style.display = 'none';
  answered = false;
}

function selectOpt(i, btn) {
  if (answered) return;
  answered = true;
  const q = questions[qIdx];
  const opts = document.querySelectorAll('.q-opt');
  opts.forEach((b, idx) => {
    if (idx === q.ans) b.classList.add('correct');
    else if (idx === i && i !== q.ans) b.classList.add('wrong');
    b.style.pointerEvents = 'none';
  });
  if (i === q.ans) score++;
  document.getElementById('q-next').style.display = 'flex';
}

function nextQuestion() {
  qIdx++;
  if (qIdx >= questions.length) {
    showResult();
  } else {
    renderQuestion();
  }
}

function showResult() {
  document.getElementById('quiz-questions').style.display = 'none';
  const res = document.getElementById('quiz-result');
  res.style.display = 'block';
  document.getElementById('r-score').textContent = score + '/5';
  const msgs = ['Ayo belajar lagi! Kamu pasti bisa lebih baik. 💪', 'Lumayan! Baca materi di atas ya. 📖', 'Bagus! Kamu sudah cukup paham. 🌟', 'Hebat! Pemahaman cerpenmu sangat baik. 🏆', 'Sempurna! Kamu ahli cerpen sejati! 🎉'];
  document.getElementById('r-msg').textContent = msgs[Math.min(score, 4)] || msgs[4];
}

function resetQuiz() {
  qIdx = 0; score = 0; answered = false;
  document.getElementById('quiz-questions').style.display = 'block';
  document.getElementById('quiz-result').style.display = 'none';
  renderQuestion();
}

function renderDots() {
  const d = document.getElementById('pdots');
  d.innerHTML = '';
  questions.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'pdot' + (i < qIdx ? ' done' : i === qIdx ? ' current' : '');
    d.appendChild(dot);
  });
}

renderQuestion();
</script>
